# Supported exchanges (must have perpetual futures):
#
#   US RESIDENTS:
#     kraken   — best US option (most states); uses kraken for spot + krakenfutures for perps
#                Note: fund both your Kraken spot and Kraken Futures accounts with USDT
#                Blocked in: NY, WA, CT, ND
#
#   NON-US:
#     binance  — global, best liquidity
#     bybit    — high liquidity, good API
#     okx      — high liquidity
#     bitget   — growing liquidity
#     gate     — wide asset selection
#
EXCHANGE=kraken
API_KEY=your_api_key_here
API_SECRET=your_api_secret_here
USE_TESTNET=true

# Comma-separated list of assets to trade (e.g. BTC,ETH)
ASSETS=BTC

MAX_POSITION_PCT=0.20
MAX_EXCHANGE_EXPOSURE_PCT=0.50
MIN_FUNDING_ENTRY_APR=5.0
MIN_FUNDING_EXIT_APR=3.0
DAILY_LOSS_LIMIT_PCT=3.0
TOTAL_DRAWDOWN_LIMIT_PCT=15.0
DELTA_REBALANCE_THRESHOLD=2.0

FUNDING_POLL_INTERVAL_S=3600
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
